# Copy to .env and fill in your Atlas values.
MONGO_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="anomaly_detection"

# Optional ingestor settings
TELEMETRY_TTL_DAYS=7
SERVICE_NAME=ingestor_service

# --- Embeddings: Google Gemini (free tier) ---
# Key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
EMBED_MODEL=gemini-embedding-001
EMBED_DIMENSIONS=768

# --- Chat / agent reasoning: Groq (OpenAI-compatible endpoint) ---
# Key from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
CHAT_MODEL=llama-3.3-70b-versatile

# --- Agent dispatch (ingestor → agent worker) ---
# stub = print to stdout (no Redis). redis = XADD to stream for agent_worker.
AGENT_DISPATCH=redis
REDIS_URL=redis://localhost:6379/0
ANOMALY_STREAM_KEY=anomaly:jobs
ANOMALY_CONSUMER_GROUP=agent-workers
ANOMALY_STREAM_MAXLEN=10000

# --- Agent worker (separate process: python -m agent_worker.main) ---
DATA_LAYER_BASE_URL=http://localhost:8000
AGENT_CONSUMER_NAME=worker-1
AGENT_CONSUMER_BLOCK_MS=20000
